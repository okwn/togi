# Worker
NODE_ENV=development
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# AI Provider (none|openai|local)
AI_PROVIDER=none
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Metrics
WORKER_METRICS_PORT=9090

# Queue Configuration
ASYNC_ANALYSIS_CONCURRENCY=5
ACTION_RETRY_CONCURRENCY=3
AUDIT_EVENTS_CONCURRENCY=10
DOMAIN_INTEL_CONCURRENCY=5
RAID_CORRELATION_CONCURRENCY=3