{
  "name": "@togi/auth",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./middleware": {
      "types": "./dist/middleware/index.d.ts",
      "default": "./dist/middleware/index.js"
    },
    "./routes": {
      "types": "./dist/routes/index.d.ts",
      "default": "./dist/routes/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit --excludeDirectories 'src/__tests__'",
    "test": "jest"
  },
  "dependencies": {
    "@togi/db": "workspace:*",
    "drizzle-orm": "^0.33.0"
  },
  "devDependencies": {
    "@fastify/cookie": "^9.3.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "fastify": "^4.25.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0",
    "zod": "^3.22.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node"
  }
}