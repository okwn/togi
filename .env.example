# Togi Environment Configuration
# Copy to .env.local and modify as needed

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# API Server
API_PORT=
API_HOST=0.0.0.0

# Web Dashboard
WEB_PORT=
WEB_HOST=0.0.0.0

# Worker
WORKER_METRICS_PORT=

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=
POSTGRES_USER=togi
POSTGRES_PASSWORD=
POSTGRES_DB=togi

# Redis
REDIS_HOST=localhost
REDIS_PORT=
REDIS_PASSWORD=

# JWT Secret for dashboard authentication
JWT_SECRET=change-me-in-production

# Environment
NODE_ENV=development
LOG_LEVEL=debug
